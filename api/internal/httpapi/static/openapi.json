{
  "openapi": "3.1.0",
  "info": {
    "title": "Deadlock Patch Notes API",
    "version": "1.0.0",
    "description": "HTTP API for patch timelines, heroes, items, and spells used by deadlock.jakubdolenek.xyz.\n\nDate filters (`from`, `to`) accept RFC3339 timestamps or date-only `YYYY-MM-DD` values in UTC."
  },
  "servers": [
    {
      "url": "https://deadlock.jakubdolenek.xyz/api",
      "description": "Production"
    }
  ],
  "tags": [
    {
      "name": "Meta"
    },
    {
      "name": "Patches"
    },
    {
      "name": "Heroes"
    },
    {
      "name": "Items"
    },
    {
      "name": "Spells"
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "tags": [
          "Meta"
        ],
        "summary": "Health check",
        "operationId": "getHealthz",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": [
                    "status"
                  ],
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                },
                "example": {
                  "status": "ok"
                }
              }
            }
          }
        }
      }
    },
    "/v1/patches": {
      "get": {
        "tags": [
          "Patches"
        ],
        "summary": "List patches",
        "operationId": "listPatches",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Page number (default 1). Invalid values fall back to 1.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 1,
              "minimum": 1
            }
          },
          {
            "name": "limit",
            "in": "query",
            "description": "Page size (default 12, max 50). Invalid values fall back to 12.",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 12,
              "minimum": 1,
              "maximum": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Patch list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatchListResponse"
                },
                "example": {
                  "items": [
                    {
                      "id": "patch-2026-03-06-update",
                      "slug": "2026-03-06-update",
                      "title": "03-06-2026 Update",
                      "publishedAt": "2026-03-06T22:36:00Z",
                      "category": "Gameplay Update",
                      "coverImageUrl": "https://assets.deadlock-api.com/v2/images/patches/2026-03-06-update/header",
                      "sourceUrl": "https://forums.playdeadlock.com/threads/03-06-2026-update.32190/",
                      "timeline": [
                        {
                          "id": "initial",
                          "kind": "initial",
                          "title": "Initial Update",
                          "releasedAt": "2026-03-06T22:36:00Z"
                        },
                        {
                          "id": "hotfix-2026-03-07",
                          "kind": "hotfix",
                          "title": "Hotfix 2026-03-07",
                          "releasedAt": "2026-03-07T18:11:00Z"
                        }
                      ]
                    }
                  ],
                  "page": 1,
                  "limit": 12,
                  "total": 1,
                  "totalPages": 1
                }
              }
            }
          }
        }
      }
    },
    "/v1/patches/{slug}": {
      "get": {
        "tags": [
          "Patches"
        ],
        "summary": "Get patch detail",
        "operationId": "getPatchBySlug",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "2026-03-06-update"
          }
        ],
        "responses": {
          "200": {
            "description": "Patch detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PatchDetail"
                },
                "example": {
                  "id": "patch-2026-03-06-update",
                  "slug": "2026-03-06-update",
                  "title": "03-06-2026 Update",
                  "publishedAt": "2026-03-06T22:36:00Z",
                  "category": "Gameplay Update",
                  "source": {
                    "type": "forum",
                    "url": "https://forums.playdeadlock.com/threads/03-06-2026-update.32190/"
                  },
                  "heroImageUrl": "https://assets.deadlock-api.com/v2/images/patches/2026-03-06-update/header",
                  "intro": "Balance update with hero, item, and ability changes.",
                  "sections": [
                    {
                      "id": "heroes",
                      "title": "Heroes",
                      "kind": "heroes",
                      "entries": [
                        {
                          "id": "abrams",
                          "entityName": "Abrams",
                          "entityIconUrl": "https://assets.deadlock-api.com/v2/heroes/abrams/icon",
                          "changes": [
                            {
                              "id": "abrams-1",
                              "text": "Base health reduced from 650 to 625."
                            }
                          ],
                          "groups": [
                            {
                              "id": "shoulder-charge",
                              "title": "Shoulder Charge",
                              "changes": [
                                {
                                  "id": "abrams-s1",
                                  "text": "Cooldown increased from 28s to 32s."
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ],
                  "timeline": [
                    {
                      "id": "initial",
                      "kind": "initial",
                      "title": "Initial Update",
                      "releasedAt": "2026-03-06T22:36:00Z",
                      "source": {
                        "type": "forum",
                        "url": "https://forums.playdeadlock.com/threads/03-06-2026-update.32190/"
                      },
                      "changes": [
                        {
                          "id": "global-1",
                          "text": "Trooper lane pressure reduced in first 5 minutes."
                        }
                      ],
                      "sections": [
                        {
                          "id": "items",
                          "title": "Items",
                          "kind": "items",
                          "entries": [
                            {
                              "id": "active-reload",
                              "entityName": "Active Reload",
                              "entityIconUrl": "https://assets.deadlock-api.com/v2/items/active-reload/icon",
                              "changes": [
                                {
                                  "id": "item-1",
                                  "text": "Perfect reload window reduced by 0.1s."
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Patch not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "patch not found"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "failed to load patch"
                }
              }
            }
          }
        }
      }
    },
    "/v1/heroes": {
      "get": {
        "tags": [
          "Heroes"
        ],
        "summary": "List heroes",
        "operationId": "listHeroes",
        "responses": {
          "200": {
            "description": "Hero list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeroListResponse"
                },
                "example": {
                  "items": [
                    {
                      "slug": "abrams",
                      "name": "Abrams",
                      "iconUrl": "https://assets.deadlock-api.com/v2/heroes/abrams/icon",
                      "lastChangedAt": "2026-03-07T18:11:00Z"
                    },
                    {
                      "slug": "dynamo",
                      "name": "Dynamo",
                      "iconUrl": "https://assets.deadlock-api.com/v2/heroes/dynamo/icon",
                      "lastChangedAt": "2026-03-06T22:36:00Z"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/v1/heroes/{heroSlug}/changes": {
      "get": {
        "tags": [
          "Heroes"
        ],
        "summary": "Get hero timeline",
        "operationId": "getHeroChanges",
        "parameters": [
          {
            "name": "heroSlug",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "abrams"
          },
          {
            "name": "skill",
            "in": "query",
            "required": false,
            "description": "Filter by skill name. Use `general` to get only general hero changes.",
            "schema": {
              "type": "string"
            },
            "example": "Shoulder Charge"
          },
          {
            "name": "from",
            "in": "query",
            "required": false,
            "description": "Inclusive UTC start. Accepts RFC3339 or YYYY-MM-DD.",
            "schema": {
              "type": "string"
            },
            "example": "2026-03-01"
          },
          {
            "name": "to",
            "in": "query",
            "required": false,
            "description": "Inclusive UTC end. Accepts RFC3339 or YYYY-MM-DD.",
            "schema": {
              "type": "string"
            },
            "example": "2026-03-12T23:59:59Z"
          }
        ],
        "responses": {
          "200": {
            "description": "Hero timeline",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HeroChangesResponse"
                },
                "example": {
                  "hero": {
                    "slug": "abrams",
                    "name": "Abrams",
                    "iconUrl": "https://assets.deadlock-api.com/v2/heroes/abrams/icon",
                    "lastChangedAt": "2026-03-07T18:11:00Z"
                  },
                  "items": [
                    {
                      "id": "2026-03-07-hotfix",
                      "kind": "hotfix",
                      "label": "Patch 03-07-2026",
                      "releasedAt": "2026-03-07T18:11:00Z",
                      "patch": {
                        "slug": "2026-03-06-update",
                        "title": "03-06-2026 Update"
                      },
                      "source": {
                        "type": "forum",
                        "url": "https://forums.playdeadlock.com/threads/03-06-2026-update.32190/"
                      },
                      "generalChanges": [
                        {
                          "id": "g-1",
                          "text": "Base health reduced from 650 to 625."
                        }
                      ],
                      "skills": [
                        {
                          "id": "shoulder-charge",
                          "title": "Shoulder Charge",
                          "changes": [
                            {
                              "id": "s-1",
                              "text": "Cooldown increased from 28s to 32s."
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid date query",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "invalid from query value"
                }
              }
            }
          },
          "404": {
            "description": "Hero not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "hero not found"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "failed to load hero changes"
                }
              }
            }
          }
        }
      }
    },
    "/v1/items": {
      "get": {
        "tags": [
          "Items"
        ],
        "summary": "List items",
        "operationId": "listItems",
        "responses": {
          "200": {
            "description": "Item list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ItemListResponse"
                },
                "example": {
                  "items": [
                    {
                      "slug": "active-reload",
                      "name": "Active Reload",
                      "iconUrl": "https://assets.deadlock-api.com/v2/items/active-reload/icon",
                      "lastChangedAt": "2026-03-07T18:11:00Z"
                    },
                    {
                      "slug": "swift-striker",
                      "name": "Swift Striker",
                      "iconUrl": "https://assets.deadlock-api.com/v2/items/swift-striker/icon",
                      "lastChangedAt": "2026-03-06T22:36:00Z"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
