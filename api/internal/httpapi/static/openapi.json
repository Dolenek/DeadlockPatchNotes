                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "invalid from query value"
                }
              }
            }
          },
          "404": {
            "description": "Item not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "item not found"
                }
              }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                "example": {
                  "error": "failed to load item changes"
                }
              }
            }
          }
        }
      }
    },
    "/v1/spells": {
      "get": {
        "tags": [
