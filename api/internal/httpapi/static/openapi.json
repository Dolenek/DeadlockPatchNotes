  },
  "components": {
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "PatchTimelineSummary": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "title",
          "releasedAt"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "releasedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PatchSummary": {
        "type": "object",
        "required": [
          "id",
          "slug",
          "title",
          "publishedAt",
          "category",
          "coverImageUrl",
          "sourceUrl"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "slug": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "publishedAt": {
            "type": "string",
            "format": "date-time"
          },
          "category": {
            "type": "string"
          },
          "coverImageUrl": {
            "type": "string"
          },
          "sourceUrl": {
            "type": "string"
          },
          "timeline": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PatchTimelineSummary"
            }
          }
        }
      },
      "PatchListResponse": {
        "type": "object",
        "required": [
          "items",
          "page",
          "limit",
          "total",
          "totalPages"
        ],
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PatchSummary"
            }
          },
          "page": {
            "type": "integer"
          },
          "limit": {
            "type": "integer"
          },
          "total": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          }
        }
      },
      "PatchSource": {
        "type": "object",
        "required": [
          "type",
          "url"
        ],
        "properties": {
          "type": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "PatchChange": {
        "type": "object",
        "required": [
          "id",
          "text"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "text": {
            "type": "string"
          }
        }
      },
      "PatchEntryGroup": {
        "type": "object",
        "required": [
          "id",
          "title",
          "changes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "iconUrl": {
            "type": "string"
          },
          "iconFallbackUrl": {
            "type": "string"
          },
          "changes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PatchChange"
            }
          }
        }
      },
      "PatchEntry": {
        "type": "object",
        "required": [
          "id",
          "entityName",
          "changes"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "entityName": {
            "type": "string"
          },
          "entityIconUrl": {
